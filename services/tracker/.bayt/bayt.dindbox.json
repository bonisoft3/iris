          "context": "docker-image://alpine/socat:latest@sha256:bfd2550379212e087dc18db2f4611f43477be4b575d660c8f18c5b9a1b2e2757"
        },
        "srcs": [
          "/usr/lib/libreadline.so.8",
          "/usr/lib/libncursesw.so.6"
        ],
        "dst": "/usr/lib/",
        "link": true,
        "parents": false,
        "exclude": []
      }
    ],
    "mounts": [],
    "secrets": {},
    "extra_hosts": [],
    "epilogue": [],
    "healthcheck": null,
    "expose": [],
    "entrypoint": null,
    "incremental": false,
