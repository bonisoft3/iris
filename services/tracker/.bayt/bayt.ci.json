      "dir": "plugins/micronaut",
      "outs": {
        "globs": [
          ".bayt/**"
        ],
        "exclude": []
      }
    }
  ],
  "chainedDeps": [
    {
      "name": "build",
      "project": "services_tracker",
      "dir": "services/tracker",
      "outs": {
        "globs": [
          "**/*"
        ],
        "exclude": [
          ".bayt/**",
          ".git/**"
        ]
      }
    },
    {
      "name": "ops",
      "project": "services_tracker",
      "dir": "services/tracker",
      "outs": {
        "globs": [
          "compose.yaml",
          ".bayt/**"
        ],
        "exclude": []
      }
    },
    {
      "name": "test-sources",
      "project": "services_tracker",
      "dir": "services/tracker",
      "outs": {
        "globs": [
          "src/it/**/*",
          "src/test/**/*"
        ],
        "exclude": []
      }
    }
  ],
  "cmds": [
    {
      "srcs": {
        "globs": [],
        "exclude": [],
        "defaultGlobs": null,
        "defaultExclude": null
      },
      "shell": "sh",
      "do": "exec docker compose up integrate --build --abort-on-container-failure --exit-code-from integrate --remove-orphans",
      "dockerfile": {
        "inject": {
          "secrets": [
            {
              "id": "docker_host",
              "var": {
                "contents": "DOCKER_HOST"
              }
            },
            {
              "id": "buildx_builder",
              "var": {
                "contents": "BUILDX_BUILDER"
              }
            },
            {
              "id": "testcontainers_host",
              "var": {
                "contents": "TESTCONTAINERS_HOST_OVERRIDE"
              }
            },
            {
              "id": "buildx_instance",
              "var": {
                "path": "/root/.docker/buildx/instances/$BUILDX_BUILDER"
              },
              "mode": "0600"
            },
            {
              "id": "docker_config",
              "var": {
                "path": "/root/.docker/config.json"
              },
              "mode": "0600"
            }
          ],
          "defaultSteps": {
            "unix-socket-forward": {
              "name": "unix-socket-forward",
              "priority": 10,
              "pre": "if [ -n \"$DOCKER_HOST\" ] && [ ! -e /var/run/docker.sock ]; then\n  ulimit -n 1048576 2>/dev/null || true\n  addr=${DOCKER_HOST#tcp://}\n  [ -n \"$addr\" ] || { echo \"dindbox: DOCKER_HOST=$DOCKER_HOST has no tcp:// address\" >&2; exit 1; }\n  socat -d0 UNIX-LISTEN:/var/run/docker.sock,fork,backlog=1024,reuseaddr \"TCP:$addr\" &\n  SOCAT_PID=$!\n  trap 'kill $SOCAT_PID 2>/dev/null || true' EXIT INT TERM\n  socat -u OPEN:/dev/null UNIX-CONNECT:/var/run/docker.sock,retry=20,interval=0.2 >/dev/null 2>&1 \\\n    || { echo \"dindbox: socat bridge to /var/run/docker.sock not ready\" >&2; exit 1; }\nfi"
            }
          },
          "steps": []
        }
      },
      "name": "builtin",
      "stop": false
    }
  ],
  "cache": {
    "full": false,
    "similar": false
  }
}