RUN --mount=type=cache,target=/root/.cache/bayt,id=services_tracker-build:/root/.cache/bayt,sharing=locked --mount=type=cache,target=/root/.gradle,id=services_tracker-build:/root/.gradle,sharing=locked --mount=type=cache,target=.gradle/configuration-cache,id=services_tracker-build:.gradle/configuration-cache,sharing=locked ["task", "bayt:build"]
