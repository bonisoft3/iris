ENV BUILDX_BAKE_ENTITLEMENTS_FS=0
ENV COMPOSE_BAKE=true
RUN --mount=type=secret,id=docker_host --mount=type=secret,id=buildx_builder --mount=type=secret,id=testcontainers_host --mount=type=secret,id=cache_scope --mount=type=secret,id=cache_scope_fallback --mount=type=secret,id=sayt_buildkit_syntax --mount=type=secret,id=sayt_no_cache --mount=type=secret,id=bayt_image_tag --mount=type=secret,id=bayt_pull_policy --mount=type=secret,id=sayt_no_cache_from --mount=type=secret,id=sayt_no_cache_to --mount=type=secret,id=depot_token --mount=type=secret,id=depot_project_id --mount=type=secret,id=depot_disable_otel --mount=type=secret,id=buildx_instance --mount=type=secret,id=docker_config,mode=0600 <<BAYT_INJECT
set -e
export DOCKER_HOST="$(cat /run/secrets/docker_host)"
export BUILDX_BUILDER="$(cat /run/secrets/buildx_builder)"
export TESTCONTAINERS_HOST_OVERRIDE="$(cat /run/secrets/testcontainers_host)"
export CACHE_SCOPE="$(cat /run/secrets/cache_scope)"
export CACHE_SCOPE_FALLBACK="$(cat /run/secrets/cache_scope_fallback)"
export BUILDKIT_SYNTAX="$(cat /run/secrets/sayt_buildkit_syntax)"
export SAYT_NO_CACHE="$(cat /run/secrets/sayt_no_cache)"
export BAYT_IMAGE_TAG="$(cat /run/secrets/bayt_image_tag)"
export BAYT_PULL_POLICY="$(cat /run/secrets/bayt_pull_policy)"
export SAYT_NO_CACHE_FROM="$(cat /run/secrets/sayt_no_cache_from)"
export SAYT_NO_CACHE_TO="$(cat /run/secrets/sayt_no_cache_to)"
export DEPOT_TOKEN="$(cat /run/secrets/depot_token)"
export DEPOT_PROJECT_ID="$(cat /run/secrets/depot_project_id)"
export DEPOT_DISABLE_OTEL="$(cat /run/secrets/depot_disable_otel)"
export BUILDX_INSTANCE="$(cat /run/secrets/buildx_instance)"
export DOCKER_AUTH_CONFIG="$(cat /run/secrets/docker_config)"
if [ -s "/run/secrets/docker_config" ]; then mkdir -p "$(dirname "/root/.docker/config.json")"; cp -p "/run/secrets/docker_config" "/root/.docker/config.json"; fi
if [ -n "$DOCKER_HOST" ] && [ ! -e /var/run/docker.sock ]; then
  ulimit -n 1048576 2>/dev/null || true
  addr=${DOCKER_HOST#tcp://}
  [ -n "$addr" ] || { echo "dindbox: DOCKER_HOST=$DOCKER_HOST has no tcp:// address" >&2; exit 1; }
  socat -d0 UNIX-LISTEN:/var/run/docker.sock,fork,backlog=1024,reuseaddr "TCP:$addr,keepalive,keepidle=30,keepintvl=15,keepcnt=4" &
  SOCAT_PID=$!
  trap 'kill $SOCAT_PID 2>/dev/null || true' EXIT INT TERM
  socat -u OPEN:/dev/null UNIX-CONNECT:/var/run/docker.sock,retry=20,interval=0.2 >/dev/null 2>&1 \
    || { echo "dindbox: socat bridge to /var/run/docker.sock not ready" >&2; exit 1; }
fi
if [ -n "$BUILDX_BUILDER" ] && [ -n "$BUILDX_INSTANCE" ]; then
  install -d -m 0700 /root/.docker/buildx/instances
  printf '%s' "$BUILDX_INSTANCE" > "/root/.docker/buildx/instances/$BUILDX_BUILDER"
  chmod 0600 "/root/.docker/buildx/instances/$BUILDX_BUILDER"
fi
if [ -n "$BUILDKIT_SYNTAX" ]; then
  # depot frontend-pin workaround (full rationale in stacks/sayt/sayt.cue)
  find /monorepo -path '*/.bayt/Dockerfile.*' -type f -exec sed -i "1i # syntax=$BUILDKIT_SYNTAX" {} \;
fi
[ -n "$DEPOT_TOKEN" ] && bake="depot bake --project $DEPOT_PROJECT_ID" || bake="docker buildx bake"
[ -f .bayt/depot.hcl ] && tgt="-f .bayt/depot.hcl depot-build" || tgt="bayt"
docker compose -f .bayt/compose.integrate.closure.yaml config | docker buildx bake --allow=fs.read=/monorepo -f - --print bayt | $bake -f - ${SAYT_NO_CACHE:+--no-cache --set "*.cache-from=" --set "*.cache-to="} ${SAYT_NO_CACHE_FROM:+--set "*.cache-from="} ${SAYT_NO_CACHE_TO:+--set "*.cache-to="} $tgt
exec docker compose -f .bayt/compose.integrate.closure.yaml up bayt --abort-on-container-failure --exit-code-from bayt --remove-orphans
BAYT_INJECT
COPY .bayt/Taskfile.yml .bayt/Taskfile.bayt.yml .bayt/bayt.ci.json .bayt/init.gradle.kts ./.bayt/

FROM busybox:musl@sha256:03db190ed4c1ceb1c55d179a0940e2d71d42130636a780272629735893292223 AS ci_bayt_ctxs
WORKDIR /monorepo/services/tracker
COPY --parents .bayt/compose.ci.yaml .bayt/Dockerfile.ci .bayt/bayt.ci.json .bayt/Taskfile.yml .bayt/Taskfile.bayt.yml .bayt/init.gradle.kts ./
COPY --from=services_tracker-dindbox_bayt /monorepo /monorepo
COPY --from=services_tracker-integrate_bayt /monorepo /monorepo
COPY --from=services_tracker-build_bayt /monorepo /monorepo
COPY --from=services_tracker-setup_bayt /monorepo /monorepo
COPY --from=libraries_logs-build_bayt /monorepo /monorepo
COPY --from=libraries_pbtables-build_bayt /monorepo /monorepo
COPY --from=libraries_xproto-build_bayt /monorepo /monorepo
COPY --from=plugins_libstoml-build_bayt /monorepo /monorepo
COPY --from=plugins_jvm-build_bayt /monorepo /monorepo
COPY --from=plugins_micronaut-build_bayt /monorepo /monorepo
COPY --from=workspaceroot-setup_bayt /monorepo /monorepo
COPY --from=plugins_libstoml-setup_bayt /monorepo /monorepo
COPY --from=plugins_jvm-setup_bayt /monorepo /monorepo
COPY --from=libraries_logs-setup_bayt /monorepo /monorepo
COPY --from=plugins_micronaut-setup_bayt /monorepo /monorepo
COPY --from=libraries_xproto-setup_bayt /monorepo /monorepo
COPY --from=libraries_pbtables-setup_bayt /monorepo /monorepo
ARG SOURCE_DATE_EPOCH
RUN touch -hd @${SOURCE_DATE_EPOCH:-0} /tmp/ref && find /monorepo -newer /tmp/ref -exec touch -hd @${SOURCE_DATE_EPOCH:-0} {} + && rm /tmp/ref
FROM scratch AS ci_bayt
COPY --from=ci_bayt_ctxs /monorepo /monorepo
