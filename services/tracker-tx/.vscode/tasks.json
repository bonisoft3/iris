{
  "version": "2.0.0",
  "tasks": [
    {
      "command": "mise x -- sh",
      "args": [
        "-c",
        "mkdir -p out && cat transcoding.yaml cloud_run_tls.yaml > out/transcoding.yaml.gcp.tpl && cat transcoding.yaml > out/transcoding.yaml.tpl"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "build",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/services/tracker-tx"
      }
    },
    {
      "command": "mise x -- sh",
      "args": [
        "-c",
        "yq . < out/transcoding.yaml.gcp.tpl"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "label": "test",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/services/tracker-tx"
      }
    }
  ]
}
