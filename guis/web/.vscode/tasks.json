{
  "version": "2.0.0",
  "tasks": [
    {
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "build",
      "type": "shell",
      "command": "task -t .bayt/Taskfile.yml bayt:build",
      "options": {
        "cwd": "${workspaceFolder}/guis/web"
      }
    },
    {
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "label": "test",
      "type": "shell",
      "command": "task -t .bayt/Taskfile.yml bayt:test",
      "options": {
        "cwd": "${workspaceFolder}/guis/web"
      }
    }
  ]
}
