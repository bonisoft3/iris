FROM guis_web-build AS launch
WORKDIR /monorepo/guis/web
COPY .bayt/Taskfile.yml .bayt/Taskfile.bayt.yml .bayt/bayt.launch.json ./.bayt/
EXPOSE 3000
CMD ["mise", "x", "--", "pnpm", "dev"]

FROM busybox:musl@sha256:03db190ed4c1ceb1c55d179a0940e2d71d42130636a780272629735893292223 AS launch_ctxs
WORKDIR /monorepo/guis/web
COPY --from=guis_web-build_srcs /monorepo /monorepo
ARG SOURCE_DATE_EPOCH
RUN touch -hd @${SOURCE_DATE_EPOCH:-0} /tmp/ref && find /monorepo -newer /tmp/ref -exec touch -hd @${SOURCE_DATE_EPOCH:-0} {} + && rm /tmp/ref
FROM scratch AS launch_srcs
COPY --from=launch_ctxs /monorepo /monorepo
