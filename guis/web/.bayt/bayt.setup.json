{
  "dockerfile": {
    "preamble": [],
    "from": {
      "ref": "workspaceroot:setup",
      "name": "workspaceroot-setup",
      "context": "service:workspaceroot-setup"
    },
    "mounts": [],
    "secrets": [],
    "epilogue": [],
    "copy": [],
    "healthcheck": null,
    "expose": [],
    "entrypoint": null,
    "incremental": false,
    "cmd": null
  },
  "name": "setup",
  "project": "guis_web",
  "dir": "guis/web",
  "activate": "",
  "srcs": {
    "globs": [],
    "exclude": []
  },
  "outs": {
    "globs": [],
    "exclude": []
  },
  "env": {
    "SHARP_IGNORE_GLOBAL_LIBVIPS": "1"
  },
  "taskfile": {
    "run": "when_changed",
    "silent": false,
    "preconditions": []
  },
  "visibility": "internal",
  "deps": [],
  "transitiveDeps": [],
  "transitiveCrossDeps": [
    {
      "name": "setup",
      "project": "workspaceroot",
      "dir": "",
      "outs": {
        "globs": [
          ".mise.toml",
          "mise.lock",
          "pnpm-lock.yaml",
          "pnpm-workspace.yaml",
          "package.json",
          "gradle/libs.versions.toml",
          "plugins/devserver/dind.sh",
          "**/package.json",
          ".task/bayt/setup.hash"
        ],
        "exclude": []
      }
    }
  ],
  "chainedDeps": [],
  "cmds": [
    {
      "srcs": {
        "globs": [
          ".mise.toml",
          "mise.lock"
        ],
        "exclude": [],
        "defaultGlobs": null,
        "defaultExclude": null
      },
      "do": "mise install",
      "name": "builtin",
      "shell": "exec",
      "stop": false
    },
    {
      "srcs": {
        "globs": [
          "package.json"
        ],
        "exclude": [],
        "defaultGlobs": null,
        "defaultExclude": null
      },
      "do": "mise x -- pnpm install --frozen-lockfile",
      "dockerfile": {
        "mounts": [
          {
            "type": "cache",
            "target": "/root/.local/share/pnpm/store",
            "sharing": "locked",
            "required": false
          }
        ]
      },
      "name": "pnpm",
      "shell": "exec",
      "stop": false
    }
  ],
  "cache": {
    "full": false,
    "similar": false
  }
}