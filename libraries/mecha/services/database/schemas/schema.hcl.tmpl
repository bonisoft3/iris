// vim: set filetype=hcl:
// Generated Atlas HCL from JSON Schema

schema "public" {
  comment = "Standard PostgreSQL public schema"
}

{{- $data := (datasource "data") -}}
{{- range $entity := $data.entities }}
table "{{ $entity.name }}" {
  schema = schema.public
  column "id" {
    type = uuid
    null = false
    default = sql("uuidv7()")
  }
  column "createdAt" {
    type = timestamptz
    null = false
    default = sql("NOW()")
  }
  column "updatedAt" {
    type = timestamptz
    null = false
    default = sql("NOW()")
  }
{{- range $propName, $propSchema := $entity.schema.properties }}
{{- if and (ne $propName "id") (ne $propName "createdAt") (ne $propName "updatedAt") (ne $propName "created_at") (ne $propName "updated_at") (not (has $propSchema "$ref")) }}
  column "{{ $propName }}" {
{{- if has $propSchema "anyOf" }}
    type = integer
{{- else if eq (index $propSchema "type") "string" }}
    type = varchar({{ if has $propSchema "maxLength" }}{{ $propSchema.maxLength }}{{ else }}255{{ end }})
{{- else if eq (index $propSchema "type") "integer" }}
    type = integer
{{- else if eq (index $propSchema "type") "number" }}
    type = decimal
{{- else if eq (index $propSchema "type") "boolean" }}
    type = boolean
{{- else if eq (index $propSchema "type") "array" }}
    type = jsonb
{{- else }}
    type = text
{{- end }}
    null = false
  }
{{- end }}
{{- end }}

  // Enrichment columns for rpk bloblang pipeline output
  column "processed_at" {
    type = timestamptz
    null = true
  }
  column "source" {
    type = varchar(100)
    null = true
  }

  primary_key {
    columns = [column.id]
  }
}
{{ end }}

