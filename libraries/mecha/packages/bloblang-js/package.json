{
  "name": "@mecha/bloblang-js",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./blobl.wasm": "./src/blobl.wasm",
    "./wasm_exec.js": "./src/wasm_exec.js",
    "./package.json": "./package.json"
  },
  "files": ["src"],
  "scripts": {
    "build:wasm": "GOOS=js GOARCH=wasm go build -o src/blobl.wasm . && cp \"$(go env GOROOT)/lib/wasm/wasm_exec.js\" src/",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
