#!/bin/sh
# Get the directory where this script lives
DIR="$(dirname "$(readlink -f "$0")")" 

# Check for Alpine and prefer musl variant if available
if [ -f /etc/alpine-release ] && [ -f "$DIR/websocat.musl.toml" ]; then
    "$DIR/../libexec/lazy-mise" trust -y -a -q .
    MISE_LOCKED=0 exec "$DIR/../libexec/lazy-mise" tool-stub "$DIR/websocat.musl.toml" "$@"
else
    "$DIR/../libexec/lazy-mise" trust -y -a -q .
    MISE_LOCKED=0 exec "$DIR/../libexec/lazy-mise" tool-stub "$DIR/websocat.toml" "$@"
fi
