{
  "version": "2.0.0",
  "tasks": [
    {
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "plugins_libstoml build",
      "type": "shell",
      "command": "task -t .bayt/Taskfile.yml bayt:build",
      "options": {
        "cwd": "${workspaceFolder}/plugins/libstoml"
      }
    },
    {
      "group": {
        "kind": "none"
      },
      "label": "plugins_libstoml doctor",
      "type": "shell",
      "command": "task -t .bayt/Taskfile.yml bayt:doctor",
      "options": {
        "cwd": "${workspaceFolder}/plugins/libstoml"
      }
    },
    {
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "label": "plugins_libstoml test",
      "type": "shell",
      "command": "task -t .bayt/Taskfile.yml bayt:test",
      "options": {
        "cwd": "${workspaceFolder}/plugins/libstoml"
      }
    }
  ]
}